---
import { ButtonLink } from "@bravinta/ui";
import { Smile } from "lucide-react";
---

<header
  class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60"
>
  <div
    class="container flex h-14 max-w-screen-2xl items-center px-4 md:px-8"
  >
    <div class="mr-4 flex">
      <a href="/" class="mr-6 flex items-center space-x-2">
        <span class="font-bold sm:inline-block">Bravinta UI</span>
      </a>
      <nav class="flex items-center space-x-6 text-sm font-medium">
        <a
          href="/docs"
          class="transition-colors hover:text-foreground/80 text-foreground"
          >Docs</a
        >
        <a
          href="/components"
          class="transition-colors hover:text-foreground/80 text-foreground/60"
          >Components</a
        >
      </nav>
    </div>
    <div
      class="flex flex-1 items-center justify-between space-x-2 md:justify-end"
    >
      <div class="w-full flex-1 md:w-auto md:flex-none">
        <!-- Search can go here -->
      </div>
      <nav class="flex items-center">
        <ButtonLink
          href="https://github.com/bravinta/ui"
          target="_blank"
          variant="ghost"
          size="icon"
        >
          <Smile className="h-4 w-4" />
          <span class="sr-only">GitHub</span>
        </ButtonLink>
      </nav>
    </div>
  </div>
</header>