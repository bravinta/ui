---
import { ButtonLink } from "@bravinta/ui";
---

<aside
  class="fixed top-14 z-30 -ml-2 hidden h-[calc(100vh-3.5rem)] w-full shrink-0 md:sticky md:block"
>
  <div class="h-full py-6 pr-6 lg:py-8 overflow-y-auto">
    <div class="w-full">
      <div class="pb-4">
        <h4 class="mb-1 rounded-md px-2 py-1 text-sm font-semibold">
          Getting Started
        </h4>
        <div class="grid grid-flow-row auto-rows-max text-sm gap-1">
          <ButtonLink
            variant="ghost"
            size="sm"
            href="/docs/introduction"
            className="w-full justify-start text-muted-foreground"
          >
            Introduction
          </ButtonLink>
          <ButtonLink
            variant="ghost"
            size="sm"
            href="/docs/installation"
            className="w-full justify-start text-muted-foreground"
          >
            Installation
          </ButtonLink>
        </div>
      </div>
      <div class="pb-4">
        <h4 class="mb-1 rounded-md px-2 py-1 text-sm font-semibold">
          Components
        </h4>
        <div class="grid grid-flow-row auto-rows-max text-sm gap-1">
          <ButtonLink
            variant="ghost"
            size="sm"
            href="/components/button"
            className="w-full justify-start text-muted-foreground"
          >
            Button
          </ButtonLink>
          <ButtonLink
            variant="ghost"
            size="sm"
            href="/components/input"
            className="w-full justify-start text-muted-foreground"
          >
            Input
          </ButtonLink>
          <ButtonLink
            variant="ghost"
            size="sm"
            href="/components/card"
            className="w-full justify-start text-muted-foreground"
          >
            Card
          </ButtonLink>
        </div>
      </div>
    </div>
  </div>
</aside>
