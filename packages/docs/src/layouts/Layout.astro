---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Sidebar from "../components/Sidebar.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>Bravinta UI - Documentation</title>
  </head>
  <body
    class="min-h-screen bg-background font-sans antialiased text-foreground"
  >
    <div class="relative flex min-h-screen flex-col">
      <Navbar />

      <div
        class="container flex-1 items-start md:grid md:grid-cols-[220px_minmax(0,1fr)] md:gap-6 lg:grid-cols-[240px_minmax(0,1fr)] lg:gap-10 px-4 md:px-8 max-w-screen-2xl"
      >
        <Sidebar />

        <main
          class="relative py-6 lg:gap-10 lg:py-8 xl:grid xl:grid-cols-[1fr_300px]"
        >
          <div class="mx-auto w-full min-w-0">
            <slot />
          </div>
          <!-- Optional Right Sidebar for Table of Contents -->
          <div class="hidden text-sm xl:block">
            <div class="sticky top-16 -mt-10 pt-4">
              <div class="space-y-2">
                <p class="font-medium">On This Page</p>
                <ul class="m-0 list-none">
                  <li class="mt-0 pt-2">
                    <a
                      href="#"
                      class="inline-block no-underline transition-colors hover:text-foreground text-muted-foreground"
                      >Overview</a>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </main>
      </div>
    </div>
  </body>
</html>
