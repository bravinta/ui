---
import Layout from "../../layouts/Layout.astro";
import { H1, P } from "@bravinta/ui";
---

<Layout>
  <div class="space-y-6">
    <div class="space-y-2">
      <H1>Button</H1>
      <P className="text-xl text-muted-foreground">
        A clickable button component with multiple variants and sizes.
      </P>
    </div>
    <P>
      The Button component supports variants like default, outline, ghost, and
      more.
    </P>
  </div>
</Layout>
