---
import Layout from "../../layouts/Layout.astro";

import { H1, P } from "@bravinta/ui";
---

<Layout>
  <div class="space-y-6">
    <div class="space-y-2">
      <H1>Input</H1>
      <P className="text-xl text-muted-foreground">
        A text input field for user data entry.
      </P>
    </div>
    <P>
      The Input component provides a styled text input with support for various
      states.
    </P>
  </div>
</Layout>
