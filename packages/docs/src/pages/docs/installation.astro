---
import Layout from "../../layouts/Layout.astro";

import { H1, P } from "@bravinta/ui";
---

<Layout>
  <div class="space-y-6">
    <div class="space-y-2">
      <H1>Installation</H1>
      <P className="text-xl text-muted-foreground">
        Get started with Bravinta UI in your project.
      </P>
    </div>
    <P> Install the package via your preferred package manager: </P>
    <pre
      class="rounded-lg border bg-muted p-4"><code>npm install @bravinta/ui</code></pre>
  </div>
</Layout>
