---
import Layout from "../../layouts/Layout.astro";

import { H1, P } from "@bravinta/ui";
---

<Layout>
  <div class="space-y-6">
    <div class="space-y-2">
      <H1>Introduction</H1>
      <P className="text-xl text-muted-foreground">
        Welcome to Bravinta UI — a collection of beautiful, accessible, and
        customizable components.
      </P>
    </div>
    <P>
      Bravinta UI provides a set of React components built with Radix UI
      primitives and styled with Tailwind CSS. Each component is fully
      accessible, customizable, and ready to use in your projects.
    </P>
  </div>
</Layout>
