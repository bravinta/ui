  },
  "sideEffects": false,
  "scripts": {
    "dev": "echo \"using source .ts directly\""
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "tailwindcss": "^4.3.0"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
