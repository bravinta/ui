{
  "name": "@bravinta/ui",
  "version": "0.1.7",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "development": "./index.ts"
    },
    "./markdown": {
      "types": "./dist/markdown.d.ts",
      "import": "./dist/markdown.js",
      "require": "./dist/markdown.cjs",
      "development": "./src/markdown/index.ts"
    },
    "./markdown.css": "./src/markdown/markdown.css",
    "./styles.css": "./src/styles/styles.css"
  },
  "packageManager": "pnpm@11.1.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/bravinta/ui"
  },
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "dev": "echo \"using source .ts directly\""
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  }
}
