{
  "name": "@bravinta/ui",
  "version": "0.1.8",
  "type": "module",
  "main": "./index.ts",
  "module": "./index.ts",
  "types": "./index.ts",
  "files": [
    "src",
    "index.ts"
  ],
  "exports": {
